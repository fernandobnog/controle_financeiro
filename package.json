{
  "name": "@controle-financeiro/workspace",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.12.1",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "dev": "turbo run dev --parallel",
    "dev:web": "pnpm --filter @controle-financeiro/web dev",
    "dev:api": "pnpm --filter @controle-financeiro/api dev",
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "test:e2e:web": "pnpm --filter @controle-financeiro/web test",
    "test:smoke:compose": "node ./scripts/smoke-compose.mjs",
    "format": "turbo run format",
    "docker:dev": "docker compose -f infra/compose/compose.base.yaml -f infra/compose/compose.dev.yaml up --build",
    "docker:test": "docker compose -f infra/compose/compose.base.yaml -f infra/compose/compose.test.yaml up --abort-on-container-exit --exit-code-from api",
    "docker:prod": "docker compose -f infra/compose/compose.base.yaml -f infra/compose/compose.prod.yaml up -d"
  },
  "devDependencies": {
    "@eslint/js": "^9.28.0",
    "@types/node": "^24.0.1",
    "eslint": "^9.28.0",
    "eslint-config-prettier": "^10.1.5",
    "eslint-plugin-vue": "^10.2.0",
    "pnpm": "10.12.1",
    "prettier": "^3.5.3",
    "tsx": "^4.20.3",
    "turbo": "^2.5.3",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.33.1"
  }
}