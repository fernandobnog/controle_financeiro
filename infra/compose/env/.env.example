NODE_ENV=development
HOST=0.0.0.0
PORT=3001
VITE_API_BASE_URL=http://localhost:3001/api
VITE_FILE_SERVER_BASE_URL=http://localhost:3002/api
VITE_DEV_USER_EMAIL=owner@familia-souza.local
VITE_DEV_USER_PASSWORD=demo12345
# VITE_API_ACCESS_TOKEN=
FILE_SERVER_PORT=3002
FILE_SERVER_URL=http://file-server:3002/api
AUTO_SEED_DB=true
APP_AUTH_SECRET=controle-financeiro-dev-secret
RAILS_ENV=development
RAILS_LOG_TO_STDOUT=true
# FILE_SERVER_DATABASE_PASSWORD=
POSTGRES_DB=controle_financeiro_dev
POSTGRES_USER=controle_financeiro
POSTGRES_PASSWORD=controle_financeiro_dev
DATABASE_URL=postgresql://controle_financeiro:controle_financeiro_dev@postgres:5432/controle_financeiro_dev
MINIO_ROOT_USER=controle-financeiro
MINIO_ROOT_PASSWORD=controle-financeiro-2026
MINIO_DEFAULT_BUCKET=documents

# ---------------------------------------------------------------------------
# Integracoes externas
# ---------------------------------------------------------------------------
# Defina como false apenas quando as chaves de IA estiverem configuradas.
# Em producao, nunca deixe true quando OPENROUTER_API_KEY ou
# LLAMAPARSE_API_KEY estiverem preenchidas.
MOCK_EXTERNAL_SERVICES=true

# OpenRouter — gateway de modelos de linguagem
# Obtenha sua chave em https://openrouter.ai/keys
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_API_KEY=
OPENROUTER_MODEL_DEFAULT=openai/gpt-4.1-mini
OPENROUTER_HTTP_REFERER=http://localhost:3000
OPENROUTER_APP_TITLE=controle-financeiro

# LlamaParse — extracao de texto de PDFs e imagens
# Obtenha sua chave em https://cloud.llamaindex.ai
LLAMAPARSE_BASE_URL=https://api.cloud.llamaindex.ai
LLAMAPARSE_API_KEY=
LLAMAPARSE_RESULT_TYPE=markdown
LLAMAPARSE_TIMEOUT_MS=120000
LLAMAPARSE_POLL_INTERVAL_MS=2000

# Cognee — memoria e contexto de IA (opcional — stub ativo por padrao)
COGNEE_BASE_URL=https://api.cognee.ai
COGNEE_API_KEY=
COGNEE_PROJECT_ID=
COGNEE_TIMEOUT_MS=30000