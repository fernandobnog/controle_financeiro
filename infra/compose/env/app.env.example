# DEPRECIADO — use infra/compose/env/.env.example como fonte unica de variaveis de ambiente.
# Este arquivo nao e mais atualizado e sera removido em versao futura.
NODE_ENV=development
HOST=0.0.0.0
PORT=3001
APP_AUTH_SECRET=defina-um-segredo-compartilhado-entre-api-e-file-server
VITE_API_BASE_URL=http://localhost:3001/api
VITE_FILE_SERVER_BASE_URL=http://localhost:3002/api
FILE_SERVER_PORT=3002
FILE_SERVER_URL=http://file-server:3002/api
AUTO_SEED_DB=true
MOCK_EXTERNAL_SERVICES=true
RAILS_ENV=development
RAILS_LOG_TO_STDOUT=true